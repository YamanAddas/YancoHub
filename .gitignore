# ── Personal data (never commit) ──
userdata.json
catbyte_history.json
*.migrated
logs/*.log
logs/
saves/

# ── Secrets / credentials (defensive — none currently in tree) ──
.env
.env.*
*.pem
*.key
*.crt
*.p12
secrets.json

# ── Cached content (downloaded at runtime) ──
cache/
__pycache__/
*.pyc

# ── BIOS files (user provides, except open-source ones) ──
bios/*.bin
bios/*.zip
bios/user/
!bios/README.md

# ── Downloaded emulators (managed by emusetup.py) ──
emulators/

# ── Claude Code ──
.claude/

# ── Virtual environment ──
venv/
.venv/

# ── OS / IDE ──
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Reference codebase (not part of YancoHub) ──
YancoDeck-main/

# ── Distribution / Build ──
dist/
build/
*.egg-info/
*.spec
